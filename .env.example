# Target database for this project
ACCESS_VCS_DATABASE=C:\Path\To\Target\Database\Testing.accdb

# Optional: explicit path to the project containing this .env file.
# Useful when running msaccess-vcs-mcp from a user-level mcp.json where the
# working directory may not be the project root and the MCP client does not
# expose workspace roots. When unset, the server resolves the project root
# from (in order):
#   1. ACCESS_VCS_PROJECT_DIR
#   2. MCP workspace roots reported by the client at runtime
#   3. Upward search from the current working directory
#   4. Upward search from the installed package location
# ACCESS_VCS_PROJECT_DIR=C:\Path\To\Project

# Optional: Disable writes for safety
# ACCESS_VCS_DISABLE_WRITES=true

# Validate Access and VCS add-in on server startup (optional)
# Set to 'true' to check component availability at startup
# ACCESS_VCS_VALIDATE_STARTUP=false

# =============================================================================
# Usage Logging Configuration
# =============================================================================
# Enable structured logging for tool usage analytics and debugging.
# Logs are stored with automatic rotation.
#
# Log Location:
# - Development mode (editable install): {project_root}/logs/
# - Package mode (pip install): ~/.msaccess-vcs-mcp/logs/
#
# Development mode is auto-detected when running from source with pyproject.toml.
# This allows collecting usage logs from client projects, then analyzing them
# alongside the source code to identify improvements.

# Enable usage logging (default: false)
# When enabled, all tool calls are logged to a JSON Lines file for analysis.
# ACCESS_VCS_ENABLE_LOGGING=false

# Custom log directory (overrides auto-detection)
# ACCESS_VCS_LOG_DIR=

# Maximum log file size in MB before rotation (default: 10)
# When the log file exceeds this size, it's rotated to a backup file.
# ACCESS_VCS_LOG_MAX_SIZE_MB=10

# Number of backup log files to keep (default: 5)
# Older backup files are deleted when this limit is exceeded.
# ACCESS_VCS_LOG_BACKUP_COUNT=5
