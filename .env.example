# Target database for this project
ACCESS_VCS_DATABASE=C:\Path\To\Target\Database\Testing.accdb

# Optional: explicit path to the project containing this .env file.
# Useful when running msaccess-vcs-mcp from a user-level mcp.json where the
# working directory may not be the project root and the MCP client does not
# expose workspace roots. When unset, the server resolves the project root
# from (in order):
#   1. ACCESS_VCS_PROJECT_DIR
#   2. MCP workspace roots reported by the client at runtime
#   3. Upward search from the current working directory
#   4. Upward search from the installed package location
# ACCESS_VCS_PROJECT_DIR=C:\Path\To\Project

# Optional: Disable writes for safety
# ACCESS_VCS_DISABLE_WRITES=true

# Validate Access and VCS add-in on server startup (optional)
# Set to 'true' to check component availability at startup
# ACCESS_VCS_VALIDATE_STARTUP=false

# Maximum time (seconds) to wait for the VCS add-in's GetVCSVersion probe
# during load_addin().  The probe runs at the start of every tool call to
# verify the add-in is healthy; this timeout catches Access being
# unresponsive (VBA break mode, modal dialog, hung COM call) without
# blocking the MCP server forever.  Default: 10 seconds.
# ACCESS_VCS_PROBE_TIMEOUT_SEC=10

# =============================================================================
# Logging Configuration
# =============================================================================
# msaccess-vcs-mcp writes two parallel JSON Lines log streams. All log
# files are prefixed with `vcs-mcp-` so they self-identify when a logs
# directory is shared with other tooling.
#
# 1) DIAGNOSTIC stream (vcs-mcp-diagnostic.jsonl) -- always-on by default.
#    Captures server lifecycle events: startup, project-root resolution,
#    .env discovery, lazy MCP-roots init. Independent of ENABLE_LOGGING
#    so you can debug exactly the case where .env was not found.
#    Location: ~/.msaccess-vcs-mcp/logs/ (override with
#    ACCESS_VCS_DIAGNOSTIC_LOG_DIR).
#
# 2) USAGE stream (vcs-mcp-usage.jsonl) -- tool calls + code-execution
#    events. Default-on as of v0.x; opt out with ENABLE_LOGGING=false.
#    Location: {project_root}/logs/ in development, ~/.msaccess-vcs-mcp/logs/
#    when installed as a package. Override with ACCESS_VCS_LOG_DIR.
#
# Sensitivity tiers inside the usage stream:
# - Audit metadata (always written when ENABLE_LOGGING=true): tool name,
#   timestamp, database, success, error, error_pattern, execution_time_ms,
#   sanitized parameters.
# - Code-execution bodies (SQL/VBA): redacted to `code_length` only by
#   default. Set ACCESS_VCS_LOG_CODE_CONTENT=true to record the full
#   `code` field (forensic mode -- adds business-data exposure risk).
# - Credential-shaped parameter keys (password, secret, token, api_key,
#   connection_string -- case-insensitive) are auto-masked to
#   "<redacted>" defense-in-depth, regardless of any other switch.

# Enable usage logging (default: true)
# Set to "false" to opt out of all tool-call and code-execution logging.
# ACCESS_VCS_ENABLE_LOGGING=true

# Disable the always-on diagnostic stream (default: false)
# Useful only if you must guarantee zero log writes from this server.
# ACCESS_VCS_DISABLE_DIAGNOSTIC_LOG=false

# Custom directories (override defaults)
# ACCESS_VCS_LOG_DIR=
# ACCESS_VCS_DIAGNOSTIC_LOG_DIR=

# Record full SQL/VBA bodies in code_execution events (default: false)
# When false, only `code_length` is logged. Enable for full forensic
# replay; do not enable on databases containing sensitive content.
# ACCESS_VCS_LOG_CODE_CONTENT=false

# Maximum usage log file size in MB before rotation (default: 10)
# ACCESS_VCS_LOG_MAX_SIZE_MB=10

# Number of rotated usage log backups to keep (default: 5)
# ACCESS_VCS_LOG_BACKUP_COUNT=5
